@{
    ViewData["Title"] = "Confirm Account";
}

<h2>Confirm Account</h2>

<p>User <strong>@ViewBag.Email</strong> registered successfully.</p>
<p>Click the button below to confirm this account.</p>

<form asp-action="ConfirmPost" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="email" value="@ViewBag.Email" />
    <button type="submit" class="btn btn-primary">Confirm Account</button>
</form>

<br />
<a asp-action="Login" class="btn btn-secondary">Go to Login</a>